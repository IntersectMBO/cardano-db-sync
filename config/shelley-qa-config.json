{
  "EnableLogMetrics": false,
  "EnableLogging": true,
  "NetworkName": "shelley_qa",
  "NodeConfigFile": "../../cardano-node/configuration/cardano/shelley_qa-config.json",
  "PrometheusPort": 8080,
  "RequiresNetworkMagic": "RequiresMagic",
  "TraceOptions": {
    "": {
      "backends": [
        "Stdout HumanFormatUncoloured"
      ],
      "detail": "DNormal",
      "severity": "Info"
    },
    "Mux": {
      "severity": "Error"
    },
    "Subscription": {
      "severity": "Error"
    }
  }
}
