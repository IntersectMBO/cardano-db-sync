  location: https://github.com/hedgehogqa/haskell-hedgehog
  tag: 4c5424db30eee67423ddd80745d03e487a223ade
  --sha256: sha256-l8pr/peym3VvlQQaYRpSSTD+i5xvEHwqf40atyk40rc=
  subdir:
