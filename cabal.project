repository cardano-haskell-packages
  url: https://chap.intersectmbo.org/
  secure: True
  root-keys:
    3e0cce471cf09815f930210f7827266fd09045445d65923e6d0238a6cd15126f
    443abb7fb497a134c343faf52f0b659bd7999bc06b7f63fa76dc99d631f9bea1
    a86a1f6ce86c449c46666bda44268677abf29b5b2d2eb5ec7af903ec2f117a82
    bcec67e8e99cabfa7764d75ad9b158d72bfacf70ca1d0ec8bc6b4406d1bf8413
    c00aae8461a256275598500ea0e187588c35a5d5d7454fb57eac18d9edb86a56
    d4a35cd3121aa00d18544bb0ac01c3e1691d618f462c46129271bccf39f7e8ee

index-state:
  , hackage.haskell.org 2024-10-10T00:52:24Z
  , cardano-haskell-packages 2024-11-26T16:00:26Z
active-repositories:
  , :rest
  , cardano-haskell-packages:override

packages:
  cardano-db
  cardano-db/test
  cardano-db-sync
  cardano-db-tool
  cardano-smash-server
  cardano-chain-gen

package cardano-chain-gen
  ghc-options: -Wall -Werror -Wredundant-constraints -Wincomplete-uni-patterns -Wincomplete-record-updates -Wpartial-fields -Wunused-imports -Wunused-packages

package cardano-db
  ghc-options: -Wall -Werror -Wredundant-constraints -Wincomplete-uni-patterns -Wincomplete-record-updates -Wpartial-fields -Wunused-imports -Wunused-packages

package cardano-db-sync
  ghc-options: -Wall -Werror -Wredundant-constraints -Wincomplete-uni-patterns -Wincomplete-record-updates -Wpartial-fields -Wunused-imports -Wunused-packages

package cardano-db-tool
  ghc-options: -Wall -Werror -Wredundant-constraints -Wincomplete-uni-patterns -Wincomplete-record-updates -Wpartial-fields -Wunused-imports -Wunused-packages

package cardano-smash-server
  ghc-options: -Wall -Werror -Wredundant-constraints -Wincomplete-uni-patterns -Wincomplete-record-updates -Wpartial-fields -Wunused-imports -Wunused-packages

package cardano-node
   -- We are using cardano-node as a library and we never use the systemd scribe, so there
   -- is no benefit to linking against it
   flags: -systemd

package postgresql-libpq
   flags: +use-pkg-config

package cryptonite
  -- Using RDRAND instead of /dev/urandom as an entropy source for key
  -- generation is dubious. Set the flag so we use /dev/urandom by default.
  flags: -support_rdrand

-- Do not depend on C++ for slightly faster utf8 parsing.
package text
  flags: -simdutf

-- ---------------------------------------------------------
-- Enable tests

tests: True
test-show-details: direct

-- Always write GHC env files, because they are needed for ghci.
write-ghc-environment-files: always

package snap-server
  -- This flag is only needed for a component of `cardano-node` and then
  -- only if the `cardano-node` is compiled with `+rtview`.
  flags: -openssl

allow-newer:
  , swagger2:aeson
  -- The version of ouroboros-consensus specified by cardano-node uses an earlier version of
  -- quickcheck-state-machine that does not compile with ghc-9.10 so we allow a never version
  -- that builds with ghc-9.10 (and earlier).
  , ouroboros-consensus:quickcheck-state-machine
  -- This is a workaround for a revision change on Hackage that increases the upper bound on
  -- https://hackage.haskell.org/package/persistent-postgresql-2.13.6.2/persistent-postgresql.cabal
  -- Since we're using srp now, we don't have access to the revision
  , persistent-postgresql:postgresql-libpq
  -- CHaPs vector-algorithms-0.9.0.1.0.0.0.0.1 has primitive <0.9 but
  -- primitive-0.9.0.0 is installed. Hackage 0.9.0.2 already relaxed this.
  , vector-algorithms:primitive

constraints:
  -- STM 2.5.2 is broken: https://github.com/haskell/stm/issues/76
  , stm >= 2.5.3.1
  -- Earlier versions do not compile with ghc-9.10.
  , quickcheck-state-machine ^>= 0.10
  , typed-protocols == 0.1.1.0
  , hashable == 1.4.7.0
  , megaparsec == 9.2.1
  , postgresql-libpq == 0.11.0.0
  , bytestring == 0.10.12.0
  , directory == 1.3.6.0
  , process == 1.6.13.2
  , time == 1.9.3
  , unix == 2.7.2.2
  , unliftio-core == 0.2.1.0
  , async-timer == 0.1.4.1
  -- Cabal 3.14 reworked FilePath references, which we use in custom-setups
  , Cabal < 3.14

-- ---------------------------------------------------------

-- The two following one-liners will cut off / restore the remainder of this file (for nix-shell users):
-- when using the "cabal" wrapper script provided by nix-shell.
-- --------------------------- 8< --------------------------
-- Please do not put any `source-repository-package` clause above this line.

-- Pinning 0.6 given by cabal freeze of 13.6.0.7:
-- any.flat ==0.6
-- Without it building fails with:
-- > rejecting: flat-0.4.4.0.0.0.0.2 (conflict: plutus-tx => flat^>=0.6)
source-repository-package
  type: git
  location: https://github.com/Quid2/flat
  tag: 3014e2dde892635c4f46037ba929ec514e0f130f
  --sha256: sha256-o6xW+CfrGfbZPBT4Bt1osZ+8vscPGd/mkqrA2esV/BY=

-- Pinning 1.5 given by cabal freeze of 13.6.0.7:
-- any.io-classes ==1.5.0.0,
-- Without it building fails with:
-- > rejecting: io-classes-0.6.0.0 (conflict: typed-protocols =>
-- > io-classes>=1.0 && <1.6)
source-repository-package
  type: git
  location: https://github.com/input-output-hk/io-sim
  tag: a22dced7d012d10227ab0fe370889665c064caf9
  --sha256: sha256-U8DERJj4t1h8kVwv9NovfKuxfTgb1E15q2EAhAT6Zes=
  subdir:
    io-classes
    io-classes-mtl
    io-sim
    si-timers
    strict-mvar
    strict-stm

-- Pinning 1.5 given by cabal freeze of 13.6.0.7:
