      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres-cardanodb"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT \n  est.synced_at - (est.seconds || ' seconds')::interval as time,\n  est.seconds as value,\n  LPAD(est.no::text, 3, '0') as metric\nFROM epoch_sync_time est\nWHERE est.synced_at IS NOT NULL\n  AND est.synced_at BETWEEN $__timeFrom() AND $__timeTo()\nORDER BY time;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Epoch Duration History",
      "type": "timeseries"
