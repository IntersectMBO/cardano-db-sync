#!/bin/bash

# This is a git pre-commit hook that runs hlint over the Haskell files you are
# about to commit. Hlint warnings are reported and the commit is aborted so you
# can fix them. It does not format code: formatting is a separate concern handled
# by fourmolu (see scripts/fourmolize.sh).
#
# You need hlint on your PATH. Use the version CI pins (hlint 3.8) so local
# results match the Hydra hlint check.

# To install this, symlink it into the checkout's hooks directory:
#   (cd .git/hooks/ && ln -s ../../scripts/git-pre-commit-hook pre-commit)
# (see doc/hlint-stylish-haskell.md).


#-------------------------------------------------------------------------------
# This is really only needed it you are starting with an empty repo.
if git rev-parse --verify HEAD >/dev/null 2>&1 ; then
  against=HEAD
else
  # Initial commit: diff against an empty tree object
  against=4b825dc642cb6eb9a060e54bf8d69288fbee4904
  fi

#-------------------------------------------------------------------------------
# Prevent files with non-ascii filenames from being committed.

if test "$(git diff --cached --name-only --diff-filter=A -z $against | LC_ALL=C tr -d '[ -~]\0' | wc -c)" != 0 ; then
  echo "Error: Attempt to add a non-ascii file name."
  echo "Commit aborted."
  exit 1
  fi

#-------------------------------------------------------------------------------
# Check the formatting of all HS files.

# Find all the files that are about to be commited.
files="$(git diff-index --name-status --cached HEAD | sed "s/^D.*$//;s/^[A-Z]+[ \t]*/ /")"

# Redirect output to stderr.
exec 1>&2

hsfiles=()
for f in $files ; do
  if test "$(echo "$f" | grep -c "\.hs$")" -gt 0 ; then
    if test "$(echo "$f" | grep -c ^PatchedPkgs)" -eq 0 ; then
      hsfiles=("${hsfiles[@]}" "$f")
      fi
    fi
  done

if test ${#hsfiles[@]} -gt 0 ; then
  hlint "${hsfiles[@]}"
  if test $? -ne 0 ; then
    echo
    echo "Commit aborted. Fix the above error before trying again."
    exit 1
    fi

  git add "${hsfiles[@]}"
  fi


#-------------------------------------------------------------------------------
# All ok!

exit 0
